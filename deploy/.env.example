# Copy this file to .env (git-ignored, so your real secret is never
# committed) and set a real random value:
#   cp .env.example .env && sed -i "s/changeme/$(openssl rand -hex 24)/" .env
#
# Required by both the hots-api container (to check the header on write
# requests) and refresh.sh (to embed the same value into the built
# dashboard so its JS can send that header). See deploy/README.md.
FEARLESS_API_TOKEN=changeme
